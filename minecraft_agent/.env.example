# ============================================================
# Minecraft AI Agent 环境变量配置模板
# 复制本文件为 .env 并填写真实值
# ============================================================

# ─────────────────────────────────────────────────────────────────
# 硅基流动 API（统一入口）
# DeepSeek 模型 + Embedding 模型都通过硅基流动调用
# API Key 和 Base URL 共用同一组配置即可
# ─────────────────────────────────────────────────────────────────
SILICONFLOW_API_KEY=sk-hedkpcbdjezaabuzbuawpmcnyeiqrkquffnbcjlztdorfxij
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ─────────────────────────────────────────────────────────────────
# DeepSeek 模型配置（通过硅基流动调用，模型名使用硅基流动格式）
# ─────────────────────────────────────────────────────────────────
# 注意：硅基流动的 DeepSeek 模型名格式为 "deepseek-ai/DeepSeek-XXX"
#       与官方 DeepSeek API 的 "deepseek-reasoner" 格式不同

# DeepSeek API Key（与 SILICONFLOW_API_KEY 相同，供 llm_router.py 读取）
DEEPSEEK_API_KEY=sk-hedkpcbdjezaabuzbuawpmcnyeiqrkquffnbcjlztdorfxij
DEEPSEEK_BASE_URL=https://api.siliconflow.cn/v1

# V3：统一使用此模型（任务分解、ReAct 推理、意图分类、技能抽象等）
DEEPSEEK_V3_MODEL=deepseek-ai/DeepSeek-V3

# ─────────────────────────────────────────────────────────────────
# RAG 查询分类模型
# QueryClassifier 调用此模型对用户提问进行语义分类
# 使用 V3 即可（快速、成本低），也可换成其他轻量模型
# ─────────────────────────────────────────────────────────────────
RAG_CLASSIFY_MODEL=deepseek-ai/DeepSeek-V3

# ─────────────────────────────────────────────────────────────────
# Embedding 模型（用于向量化文档和查询）
# ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3

# ─────────────────────────────────────────────────────────────────
# ChromaDB 本地向量数据库路径
# ─────────────────────────────────────────────────────────────────
CHROMA_DB_PATH=./data/chroma_db

# ─────────────────────────────────────────────────────────────────
# 知识库 .md 文件存放路径
# ─────────────────────────────────────────────────────────────────
KNOWLEDGE_BASE_PATH=./data/knowledge_base

# ─────────────────────────────────────────────────────────────────
# WebSocket 服务器配置
# ─────────────────────────────────────────────────────────────────
WS_HOST=localhost
WS_PORT=8765

# ─────────────────────────────────────────────────────────────────
# Agent 行为参数
# ─────────────────────────────────────────────────────────────────
# ReAct 最大循环步数（超出则触发兜底回复）
MAX_REACT_STEPS=10

# 短期记忆滑动窗口大小（对话轮数）
SHORT_TERM_MEMORY_SIZE=20

# 长期记忆检索返回条数
LONG_TERM_MEMORY_TOP_K=5
