# ============================================================
# Minecraft AI Agent 环境变量配置模板
# 复制本文件为 .env 并填写真实值
# ============================================================
# 默认使用 Mineflayer 连接 MC，无需 Java Fabric Mod。
# 主 LLM 默认使用 DeepSeek（性价比高），后续可自行更换更强模型。

# ─────────────────────────────────────────────────────────────────
# Minecraft 与 Mineflayer
# ─────────────────────────────────────────────────────────────────
MC_HOST=172.29.0.1 # 172.29.0.1 wsl和windows的虚拟网卡ip地址
MC_PORT=25565
MC_USERNAME=Agent
MINEFLAYER_PORT=3000

# ─────────────────────────────────────────────────────────────────
# LLM 分层路由：小模型（分类/Critic/技能抽象）+ 大模型（代码生成/任务分解/闲聊）
# ─────────────────────────────────────────────────────────────────
# 小模型（硅基流动，用于 classify / Critic / RAG 分类 / 技能抽象）
SILICONFLOW_API_KEY=###
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
FAST_MODEL=Qwen/Qwen2.5-7B-Instruct
# 未配置 SILICONFLOW_API_KEY 时，classify 回退到 DEEPSEEK 大模型

# 大模型（DeepSeek 官方，用于代码生成、任务分解、闲聊）
DEEPSEEK_API_KEY=###
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_V3_MODEL=deepseek-chat
DEEPSEEK_LLM_TIMEOUT=90

# 单次代码执行超时（毫秒）、任务重试次数
CODE_TIMEOUT_MS=300000
MAX_TASK_RETRIES=4

# ─────────────────────────────────────────────────────────────────
# RAG / 知识库（可选；主流程未传 retriever 时不触发 RAG 检索）
# ─────────────────────────────────────────────────────────────────
CHROMA_DB_PATH=./data/chroma_db
KNOWLEDGE_BASE_PATH=./data/knowledge_base
# RAG 查询分类用的模型；若希望与主流程一致走小模型，可设为与 FAST_MODEL 相同
RAG_CLASSIFY_MODEL=Qwen/Qwen2.5-7B-Instruct
EMBEDDING_MODEL=BAAI/bge-m3

# ─────────────────────────────────────────────────────────────────
# 记忆（短期/长期；当前仅写入，未在 _build_context 中注入）
# ─────────────────────────────────────────────────────────────────
SHORT_TERM_MEMORY_SIZE=20
LONG_TERM_MEMORY_TOP_K=5

# ─────────────────────────────────────────────────────────────────
# Agent 行为 / 聊天
# ─────────────────────────────────────────────────────────────────
MAX_REACT_STEPS=12
# / 命令后同用户多少秒内的下一条消息视为命令反馈而忽略（不交给 Agent）
FEEDBACK_SKIP_SEC=2

# ─────────────────────────────────────────────────────────────────
# 遗留：WebSocket 配置（Fabric Mod 方案用，默认 Mineflayer 可不填）
# ─────────────────────────────────────────────────────────────────
# WS_HOST=localhost
# WS_PORT=8765
