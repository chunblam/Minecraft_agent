# ============================================================
# Minecraft AI Agent 环境变量配置模板
# 复制本文件为 .env 并填写真实值
# ============================================================
# 默认使用 Mineflayer 连接 MC，无需 Java Fabric Mod。
# 主 LLM 默认使用 DeepSeek（性价比高），后续可自行更换更强模型。

# ─────────────────────────────────────────────────────────────────
# Minecraft 与 Mineflayer
# ─────────────────────────────────────────────────────────────────
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=Agent
MINEFLAYER_PORT=3000

# ─────────────────────────────────────────────────────────────────
# LLM：当前由 llm_router.py 读取 DEEPSEEK_*（未使用 LLM_API_KEY/LLM_BASE_URL）
# ─────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_or_siliconflow_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 硅基流动示例: DEEPSEEK_BASE_URL=https://api.siliconflow.cn/v1
# 模型名：官方 deepseek-chat；硅基流动 deepseek-ai/DeepSeek-V3
DEEPSEEK_V3_MODEL=deepseek-chat
DEEPSEEK_LLM_TIMEOUT=90

# ─────────────────────────────────────────────────────────────────
# RAG / 知识库（可选；主流程未传 retriever 时不触发 RAG 检索）
# ─────────────────────────────────────────────────────────────────
CHROMA_DB_PATH=./data/chroma_db
KNOWLEDGE_BASE_PATH=./data/knowledge_base
RAG_CLASSIFY_MODEL=deepseek-ai/DeepSeek-V3
EMBEDDING_MODEL=BAAI/bge-m3

# ─────────────────────────────────────────────────────────────────
# 记忆（短期/长期；当前仅写入，未在 _build_context 中注入）
# ─────────────────────────────────────────────────────────────────
SHORT_TERM_MEMORY_SIZE=20
LONG_TERM_MEMORY_TOP_K=5

# ─────────────────────────────────────────────────────────────────
# Agent 行为
# ─────────────────────────────────────────────────────────────────
MAX_REACT_STEPS=12
MAX_TASK_RETRIES=4

# ─────────────────────────────────────────────────────────────────
# 遗留：WebSocket 配置（Fabric Mod 方案用，默认 Mineflayer 可不填）
# ─────────────────────────────────────────────────────────────────
# WS_HOST=localhost
# WS_PORT=8765
